# Ignore Visual Studio temporary files, build results, and user-specific files
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider/JetBrains project files
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Other common ignores
